generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Feedback {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  category  String
  rating    Int
  message   String
  notify    Boolean
  createdAt DateTime @default(now())
}
